# ─── Base de datos ───────────────────────────────────────────────────────────
# SQLite (desarrollo) — cambia a PostgreSQL en producción
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-aleatorio-con-openssl-rand-base64-32"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Obtén tus claves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# ID del precio mensual creado en Stripe (€39/mes)
STRIPE_PRICE_ID="price_..."

# ─── Anthropic (IA para respuestas) ──────────────────────────────────────────
# Obtén tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Ejemplo con Gmail: activa "contraseñas de aplicación" en tu cuenta
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion"
SMTP_FROM="ReputaciónPro <noreply@tudominio.com>"

# ─── Google My Business API (Opcional — necesario para reseñas reales) ────────
# Sigue la guía en README.md para configurar OAuth con Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
